[include]
    path = ~/.gitconfg.os
	path = ~/.gitconfig_shared
[user]
	name = juro106
	email = hiyuman@gmail.com
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[difftool "sourcetree"]
	cmd = '' \"$LOCAL\" \"$REMOTE\"
[mergetool "sourcetree"]
	cmd = "'' "
	trustExitCode = true
[credential "helperselector"]
	selected = <no helper>
[http]
	proxy = http://
[https]
	proxy = http://
